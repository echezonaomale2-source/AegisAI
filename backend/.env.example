AEGIS_APP_VERSION=12.0.0
AEGIS_DEBUG=false
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_TO_FILE=true
AEGIS_CORS_ORIGINS=*
AEGIS_ENCRYPT_TRADE_RECORDS=true
AEGIS_ENCRYPT_MEMORY_AT_REST=true
AEGIS_ENCRYPT_CHARTS=true
AEGIS_MIN_CONFIDENCE_THRESHOLD=70
# Optional: set a stable Fernet key (otherwise auto-created under storage/.encryption_key)
# AEGIS_ENCRYPTION_KEY=
